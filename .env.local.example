# Frontend (Vite)
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Convex deployment (gerado por `npx convex dev`)
CONVEX_DEPLOYMENT=dev:your-deployment

# --- Variáveis do Convex Auth (no DEPLOYMENT, não no .env.local) ---
# Configure uma vez com:
#   npx @convex-dev/auth --web-server-url http://localhost:5173
# Ou manualmente no dashboard Convex: Settings → Environment Variables
#
# Obrigatórias:
#   JWT_PRIVATE_KEY
#   JWKS
#   SITE_URL=http://localhost:5173
#   CONVEX_SITE_URL (geralmente já definida pelo CLI)
