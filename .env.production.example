# Variáveis para Vercel (Production) — Project Settings → Environment Variables
# Use o deployment de PRODUÇÃO do Convex (npx convex deploy), não o dev.

VITE_CONVEX_URL=https://tidy-wolverine-260.convex.cloud
VITE_CONVEX_SITE_URL=https://tidy-wolverine-260.convex.site

# No Convex Dashboard (deployment PROD) → Settings → Environment Variables:
#   SITE_URL=https://seu-app.vercel.app
#   JWT_PRIVATE_KEY=...
#   JWKS=...
#   CONVEX_SITE_URL=https://tidy-wolverine-260.convex.site
#
# Gerar auth para produção:
#   npx @convex-dev/auth --web-server-url https://seu-app.vercel.app
#   (selecione deployment de produção quando solicitado)
